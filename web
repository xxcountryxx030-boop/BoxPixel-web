    <title>BoxPixelWeb</title>
    <style>
        /* Estilos básicos */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #121212;
            color: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        header {
            text-align: center;
            margin-bottom: 2rem;
        }

        h1 {
            font-size: 3rem;
            color: #00ffcc;
            text-transform: uppercase;
            letter-spacing: 5px;
            margin-bottom: 0.5rem;
        }

        .container {
            text-align: center;
            padding: 2rem;
            border: 2px solid #333;
            border-radius: 15px;
            background: #1e1e1e;
        }

        p {
            font-size: 1.2rem;
            color: #cccccc;
        }
    </style>
</head>
<body>

    <header>
        <h1>BoxPixelWeb</h1>
